# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Frontend build files
node_modules/
/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/test/unit/coverage/
/test/e2e/reports/
selenium-debug.log

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw*

# Project specific files
README.md
docker-compose.yml
*.jsx
*.css

# Specific directory patterns from your output
app/__pycache__/
app/api/endpoints/__pycache__/
app/api/rag/__pycache__/
data/

# Terraform specific ignores
**/.terraform/*

# .tfstate files - these contain sensitive info and should be kept out of git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude terraform lock files if you're collaborating with people on different terraform versions
.terraform.lock.hcl

# Exclude plan output files
tfplan
*.tfplan

# Exclude variable files that might contain sensitive data
*.tfvars
*.tfvars.json

# Exclude CLI configuration files
.terraformrc
terraform.rc

# Exclude override files as they're usually environment-specific
override.tf
override.tf.json
*_override.tf
*_override.tf.json
